# .editorconfig — Consistent formatting for all contributors.
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Dockerfile*]
indent_size = 4

[*.sh]
indent_size = 4

[*.json]
indent_size = 2

[Caddyfile]
indent_style = tab
