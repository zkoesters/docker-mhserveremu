{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Docker image versions in test helper scripts",
      "managerFilePatterns": [
        "/^test/.*\\.sh$/"
      ],
      "matchStrings": [
        "_IMAGE=\"(?<depName>[a-z0-9][a-z0-9._/-]+):(?<currentValue>[A-Za-z0-9._-]+)\""
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
